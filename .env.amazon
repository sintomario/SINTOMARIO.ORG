# Amazon Product Advertising API 5.0 Configuration
# Obtener desde: https://afiliados.amazon.es/assoc_credentials/home
# NOTA: Configurar estas variables en GitHub Secrets para producción

AMAZON_ACCESS_KEY_ID=${AMAZON_ACCESS_KEY_ID}
AMAZON_SECRET_ACCESS_KEY=${AMAZON_SECRET_ACCESS_KEY}
AMAZON_TAG=sintomario-20
AMAZON_REGION=es-east-1  # Para Amazon.es
AMAZON_LOCALE=es         # Español

# Configuración adicional
AMAZON_API_VERSION=5.0
AMAZON_TIMEOUT=30
AMAZON_RETRY_ATTEMPTS=3
