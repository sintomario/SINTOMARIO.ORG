        "medical-disclaimer": {
          "background": "#f59e0b",
          "text": "#ef4444",
          "size": "6px",
          "position": "fixed",
          "bottom": "10px",
          "z-index": "9999",
          "rule": "INAMOVIBLE - Prioridad absoluta"
        }
      },
      
      "typography": {
        "font-families": {
          "headings": "'Inter Display', system-ui, sans-serif",
          "body": "'Inter', system-ui, sans-serif",
          "accent": "'Playfair Display', Georgia, serif",
          "technical": "'JetBrains Mono', 'Fira Code', monospace"
        },
        "scales": {
          "headings": {
            "h1": "clamp(2rem, 5vw, 4rem)",
            "h2": "clamp(1.75rem, 4vw, 3rem)",
            "h3": "clamp(1.5rem, 3vw, 2.5rem)",
            "h4": "clamp(1.25rem, 2.5vw, 2rem)",
            "h5": "clamp(1.125rem, 2vw, 1.75rem)",
            "h6": "clamp(1rem, 1.5vw, 1.5rem)"
          },
          "body": {
            "large": "clamp(1.125rem, 2vw, 1.25rem)",
            "base": "clamp(1rem, 2vw, 1.125rem)",
            "small": "clamp(0.875rem, 1.5vw, 1rem)",
            "xs": "clamp(0.75rem, 1vw, 0.875rem)"
          },
          "disclaimer": "6px"
        }
      },
      
      "spacing": {
        "base-unit": "8px",
        "scale": {
          "micro": "2px",
          "tiny": "4px",
          "xs": "8px",
          "sm": "12px",
          "md": "16px",
          "lg": "24px",
          "xl": "32px",
          "2xl": "48px",
          "3xl": "64px",
          "4xl": "96px",
          "5xl": "128px"
        },
        "therapeutic": {
          "breathing-room": {
            "inhale": "24px",
            "exhale": "32px",
            "hold": "48px"
          }
        }
      },
      
      "borders": {
        "radius": {
          "sm": "4px",
          "md": "8px",
          "lg": "12px",
          "xl": "16px",
          "2xl": "24px",
          "full": "50%"
        },
        "widths": {
          "thin": "1px",
          "medium": "2px",
          "thick": "4px"
        }
      },
      
      "shadows": {
        "sm": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
        "md": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
        "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)",
        "xl": "0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1)",
        "therapeutic": "0 8px 24px rgba(59, 130, 246, 0.15)"
      },
      
      "transitions": {
        "fast": "0.15s ease-in-out",
        "normal": "0.3s ease-in-out",
        "slow": "0.5s ease-in-out"
      }
    },
    
    "components": {
      "buttons": {
        "primary-therapeutic": {
          "background": "#3b82f6",
          "color": "#ffffff",
          "border-radius": "8px",
          "padding": "12px 24px",
          "font-weight": "500",
          "transition": "all 0.3s ease-in-out"
        },
        "secondary-calm": {
          "background": "transparent",
          "color": "#3b82f6",
          "border": "2px solid #3b82f6",
          "border-radius": "8px",
          "padding": "10px 22px"
        },
        "accent-transform": {
          "background": "#8b5cf6",
          "color": "#ffffff",
          "border-radius": "12px",
          "padding": "14px 28px",
          "font-weight": "600"
        }
      },
      
      "cards": {
        "therapeutic-content": {
          "background": "#ffffff",
          "border": "1px solid #e2e8f0",
          "border-radius": "12px",
          "padding": "24px",
          "box-shadow": "0 2px 8px rgba(0, 0, 0, 0.05)"
        },
        "somatic-zone": {
          "background": "#f8fafc",
          "border": "2px solid #e2e8f0",
          "border-radius": "16px",
          "padding": "32px"
        },
        "medical-info": {
          "background": "#eff6ff",
          "border-left": "4px solid #3b82f6",
          "border-radius": "8px",
          "padding": "20px"
        }
      },
      
      "forms": {
        "therapeutic-input": {
          "background": "#ffffff",
          "border": "2px solid #e2e8f0",
          "border-radius": "8px",
          "padding": "12px 16px",
          "font-size": "1rem"
        },
        "somatic-textarea": {
          "background": "#ffffff",
          "border": "2px solid #e2e8f0",
          "border-radius": "12px",
          "padding": "16px",
          "min-height": "120px"
        }
      }
    },
    
    "layout": {
