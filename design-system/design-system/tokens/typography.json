{
  "atlas-therapeutic-typography": {
    "font-families": {
      "headings": {
        "family": "'Inter Display', system-ui, sans-serif",
        "weights": {
          "light": 300,
          "regular": 400,
          "medium": 500,
          "semibold": 600,
          "bold": 700,
          "extrabold": 800
        },
        "styles": ["normal", "italic"]
      },
      "body": {
        "family": "'Inter', system-ui, sans-serif",
        "weights": {
          "light": 300,
          "regular": 400,
          "medium": 500,
          "semibold": 600,
          "bold": 700
        },
        "styles": ["normal", "italic"]
      },
      "accent": {
        "family": "'Playfair Display', Georgia, serif",
        "weights": {
          "regular": 400,
          "medium": 500,
          "semibold": 600,
          "bold": 700
        },
        "styles": ["normal", "italic"]
      },
      "technical": {
        "family": "'JetBrains Mono', 'Fira Code', monospace",
        "weights": {
          "light": 300,
          "regular": 400,
          "medium": 500,
          "semibold": 600,
          "bold": 700
        },
        "styles": ["normal", "italic"]
      }
    },
    "font-sizes": {
      "fluid-scale": {
        "min": "320px",
        "max": "1440px"
      },
      "headings": {
        "h1": {
          "min": "2rem",
          "max": "4rem",
          "line-height": "1.1",
          "letter-spacing": "-0.02em"
        },
        "h2": {
          "min": "1.75rem",
          "max": "3rem",
          "line-height": "1.2",
          "letter-spacing": "-0.01em"
        },
        "h3": {
          "min": "1.5rem",
          "max": "2.5rem",
          "line-height": "1.3",
          "letter-spacing": "0"
        },
        "h4": {
          "min": "1.25rem",
          "max": "2rem",
          "line-height": "1.4",
          "letter-spacing": "0"
        },
        "h5": {
          "min": "1.125rem",
          "max": "1.75rem",
          "line-height": "1.5",
          "letter-spacing": "0.01em"
        },
        "h6": {
          "min": "1rem",
          "max": "1.5rem",
          "line-height": "1.6",
          "letter-spacing": "0.02em"
        }
      },
      "body": {
        "large": {
          "min": "1.125rem",
          "max": "1.25rem",
          "line-height": "1.7",
          "letter-spacing": "0"
        },
        "base": {
          "min": "1rem",
          "max": "1.125rem",
          "line-height": "1.6",
          "letter-spacing": "0"
        },
        "small": {
          "min": "0.875rem",
          "max": "1rem",
          "line-height": "1.5",
          "letter-spacing": "0.01em"
        },
        "xs": {
          "min": "0.75rem",
          "max": "0.875rem",
          "line-height": "1.4",
          "letter-spacing": "0.02em"
        }
      },
      "specialized": {
        "disclaimer": {
          "size": "6px",
          "line-height": "1",
          "letter-spacing": "0.05em",
          "transform": "uppercase",
          "weight": 700
        },
        "technical": {
          "min": "0.875rem",
          "max": "1rem",
          "line-height": "1.5",
          "letter-spacing": "0"
        },
        "accent": {
          "min": "1.125rem",
          "max": "1.5rem",
          "line-height": "1.4",
          "letter-spacing": "0.01em"
        }
      }
    }
  },
  "semantic-typography": {
    "therapeutic-headings": {
      "hero": {
        "font-family": "'Inter Display'",
        "font-size": "clamp(2.5rem, 5vw, 4rem)",
        "font-weight": 700,
        "line-height": 1.1,
        "letter-spacing": "-0.02em",
        "color": "#1e293b"
      },
      "section": {
        "font-family": "'Inter Display'",
        "font-size": "clamp(1.75rem, 4vw, 3rem)",
        "font-weight": 600,
        "line-height": 1.2,
        "letter-spacing": "-0.01em",
        "color": "#1e293b"
      },
      "subsection": {
        "font-family": "'Inter Display'",
        "font-size": "clamp(1.5rem, 3vw, 2.5rem)",
        "font-weight": 600,
        "line-height": 1.3,
        "color": "#1e293b"
      }
    },
    "body-therapeutic": {
      "primary": {
        "font-family": "'Inter'",
        "font-size": "clamp(1rem, 2vw, 1.125rem)",
        "font-weight": 400,
        "line-height": 1.6,
        "color": "#1e293b"
      },
      "secondary": {
        "font-family": "'Inter'",
        "font-size": "clamp(0.875rem, 1.5vw, 1rem)",
        "font-weight": 400,
        "line-height": 1.5,
        "color": "#475569"
      },
      "accent": {
        "font-family": "'Playfair Display'",
        "font-size": "clamp(1.125rem, 2.5vw, 1.5rem)",
        "font-weight": 400,
        "font-style": "italic",
        "line-height": 1.4,
        "color": "#3b82f6"
      },
      "technical": {
        "font-family": "'JetBrains Mono'",
        "font-size": "clamp(0.875rem, 1.5vw, 1rem)",
        "font-weight": 400,
        "line-height": 1.5,
        "color": "#64748b"
      }
    },
    "medical-disclaimer": {
      "font-family": "'Inter'",
      "font-size": "6px",
      "font-weight": 700,
      "line-height": 1,
      "letter-spacing": "0.05em",
      "text-transform": "uppercase",
      "color": "#ef4444"
    }
  }
}
