{
  "name": "atlas-somatico-editorial",
  "version": "1.0.0",
  "description": "Atlas Somático Editorial - Sistema terapéutico digital con cartografía corporal interactiva",
  "main": "templates-atlas/comprehensive-experience.html",
  "scripts": {
    "dev": "python -m http.server 8080",
    "build": "npm run build-css && npm run build-js",
    "build-css": "postcss assets-atlas/css/main.css -o assets-atlas/css/main.min.css",
    "build-js": "webpack --mode production",
    "test": "npm run test:unit && npm run test:a11y && npm run test:perf",
    "test:unit": "jest tests/unit/",
    "test:a11y": "axe tests/accessibility/",
    "test:perf": "lighthouse http://localhost:8080 --output=json --output-path=./reports/lighthouse.json",
    "lint": "eslint assets-atlas/js/",
    "lint:fix": "eslint assets-atlas/js/ --fix",
    "validate": "npm run lint && npm run test",
    "deploy:staging": "rsync -avz --delete assets-atlas/ $STAGING_SERVER/assets/ && rsync -avz --delete templates-atlas/ $STAGING_SERVER/templates/",
    "deploy:prod": "rsync -avz --delete assets-atlas/ $PROD_SERVER/assets/ && rsync -avz --delete templates-atlas/ $PROD_SERVER/templates/",
    "optimize:images": "imagemin assets-atlas/images/* --out-dir=assets-atlas/images/optimized",
    "analyze": "webpack-bundle-analyzer dist/js/bundle.js",
    "serve": "python -m http.server 8080 --directory .",
    "start": "npm run dev"
  },
  "keywords": [
    "atlas-somatico",
    "terapia",
    "cartografia-corporal",
    "salud-mental",
    "bienestar",
    "scrollytelling",
    "visualizacion-medica",
    "accesibilidad",
    "wcag",
    "progressive-web-app"
  ],
  "author": "Atlas Somático Editorial Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/atlas-somatico/editorial"
  },
  "bugs": {
    "url": "https://github.com/atlas-somatico/editorial/issues"
  },
  "homepage": "https://atlas-somatico.com",
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "axe-core": "^4.7.0",
    "eslint": "^8.42.0",
    "eslint-config-standard": "^17.1.0",
    "imagemin": "^8.0.0",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^9.0.2",
    "jest": "^29.5.0",
    "lighthouse": "^10.2.0",
    "postcss": "^8.4.24",
    "postcss-cli": "^10.1.0",
    "postcss-preset-env": "^8.5.0",
    "cssnano": "^6.0.1",
    "webpack": "^5.88.0",
    "webpack-bundle-analyzer": "^4.9.0",
    "webpack-cli": "^5.1.0",
    "terser-webpack-plugin": "^5.3.9",
    "css-minimizer-webpack-plugin": "^5.0.1"
  },
  "dependencies": {
    "chart.js": "^4.3.0",
    "chartjs-plugin-zoom": "^2.0.1",
    "chartjs-plugin-selection": "^2.0.1"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": ["<rootDir>/tests/setup.js"],
    "collectCoverageFrom": [
      "assets-atlas/js/**/*.js",
      "!assets-atlas/js/**/*.min.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "eslintConfig": {
    "extends": [
      "standard"
    ],
    "env": {
      "browser": true,
      "es2021": true,
      "jest": true
    },
    "globals": {
      "Chart": "readonly",
      "IntersectionObserver": "readonly",
      "ResizeObserver": "readonly",
      "MutationObserver": "readonly",
      "localStorage": "readonly",
      "sessionStorage": "readonly"
    }
  },
  "postcss": {
    "plugins": [
      "postcss-preset-env",
      "cssnano"
    ]
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "browsers": ["> 1%", "last 2 versions", "not dead"]
          }
        }
      ]
    ]
  }
}
