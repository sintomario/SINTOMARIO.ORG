# Environment variables for SINTOMARIO.ORG
# Copy this file to .env and fill in your actual values

# Production environment
SABIA_ENV=production

# Amazon Associates configuration
AMAZON_TAG=sintomario-20

# Optional: Amazon Product Advertising API (when available)
# AMAZON_ACCESS_KEY_ID=your_access_key_here
# AMAZON_SECRET_ACCESS_KEY=your_secret_key_here
# AMAZON_ASSOCIATES_TAG=sintomario-20

# Cloudflare DNS configuration (optional - for automated DNS management)
# Copy .env.cloudflare.example to .env.cloudflare and fill with your tokens
# CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
# CLOUDFLARE_ZONE_ID=47ebfbadef2862ed21a26b1902238c89
