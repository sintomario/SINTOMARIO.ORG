# ═══════════════════════════════════════════════════════
# SABIA.INFO — Variables de entorno
# Copia este archivo como .env.local y llena los valores
# NUNCA subas .env.local a GitHub (está en .gitignore)
# ═══════════════════════════════════════════════════════

# ── DOMINIO ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://sabia.info
NEXT_PUBLIC_SITE_NAME=SABIA.INFO

# ── BASE DE DATOS · Vercel Postgres (Neon) ─────────────
# Se obtiene en: vercel.com → tu proyecto → Storage → Postgres → .env.local
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/sabia?sslmode=require
POSTGRES_URL=postgresql://USER:PASSWORD@HOST:5432/sabia?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://USER:PASSWORD@HOST:5432/sabia?sslmode=require

# ── REDIS · Vercel KV ───────────────────────────────────
# Se obtiene en: vercel.com → tu proyecto → Storage → KV → .env.local
KV_URL=redis://...
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...
KV_REST_API_READ_ONLY_TOKEN=...

# ── STRIPE ──────────────────────────────────────────────
# Se obtiene en: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Se obtiene en: dashboard.stripe.com → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ── GEMINI API (generación automática) ──────────────────
# Se obtiene en: makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# ── KO-FI ────────────────────────────────────────────────
# Se obtiene en: ko-fi.com → tu página → Donation Settings → Widget ID
NEXT_PUBLIC_KOFI_ID=TU_ID_KOFI

# ── AMAZON AFFILIATES ────────────────────────────────────
NEXT_PUBLIC_AMAZON_TAG=sabia-21

# ── DASHBOARD AUTH ───────────────────────────────────────
# Contraseña simple para el dashboard (cambia por algo seguro)
DASHBOARD_PASSWORD=tu-contrasena-segura-aqui

# ── VERCEL DEPLOY HOOK (para GitHub Actions) ────────────
# Se obtiene en: vercel.com → tu proyecto → Settings → Git → Deploy Hooks
VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/...

# ── ANALYTICS · Plausible (opcional) ────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=sabia.info
