// ═══════════════════════════════════════════════════════
// SABIA.INFO — Prisma Schema
// ═══════════════════════════════════════════════════════

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

generator client {
  provider = "prisma-client-js"
}

model Reading {
  id                String   @id
  sabia_index       String   @unique
  url_slug          String   @unique
  zona              String
  contexto          String
  herida            String
  tcm_elemento      String?
  meridiano         String?
  fase              String   @default("cronica")
  cie10             String?
  tipo_condicion    String   @default("fisica")
  emocion_raiz      String
  lectura_libre     String?  @db.Text
  lectura_pago      String?  @db.Text
  jung_analisis     String?  @db.Text
  microterapi       String?  @db.Text
  maxima_sabia      String?  @db.Text
  maxima_suntzu     String?  @db.Text
  maxima_luz        String?  @db.Text
  maxima_sabia_src  String?
  maxima_suntzu_src String?
  maxima_luz_src    String?
  og_title          String?
  og_desc           String?
  keywords_json     String?  @db.Text
  tags_json         String?  @db.Text
  share_wa_text     String?
  schema_ld         String?  @db.Text
  ref_autor         String?
  ref_libro         String?
  ref_asin          String?
  afirmacion        String?
  pregunta_cierre   String?
  patron_apertura   String?
  status            String   @default("pendiente")
  premium           Boolean  @default(true)
  palabras          Int      @default(0)
  idioma            String   @default("es")
  fuente            String   @default("motor_v2")
  views             Int      @default(0)
  unlocks           Int      @default(0)
  shares            Int      @default(0)
  score_resonancia  Float    @default(0.0)
  avg_time_sec      Int      @default(0)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  published_at      DateTime?
  products          Product[]
  metrics           MetricsDaily[]
  unlock_records    Unlock[]

  @@index([zona, contexto])
  @@index([status])
  @@index([score_resonancia(sort: Desc)])
  @@map("readings")
}

model Unlock {
  id             String    @id @default(uuid())
  reading_id     String
  stripe_session String?   @unique
  stripe_pi      String?
  amount_cents   Int       @default(300)
  currency       String    @default("usd")
  status         String    @default("pending")
  access_token   String?   @unique
  token_expires  DateTime?
  user_country   String?
  created_at     DateTime  @default(now())
  reading        Reading   @relation(fields: [reading_id], references: [id])

  @@index([access_token])
  @@index([reading_id])
  @@map("unlocks")
}

model MetricsDaily {
  id          Int      @id @default(autoincrement())
  reading_id  String
  date        String
  views       Int      @default(0)
  unlocks     Int      @default(0)
  shares      Int      @default(0)
  revenue_cts Int      @default(0)
  avg_sec     Int      @default(0)
  bounce_pct  Float    @default(0)
  reading     Reading  @relation(fields: [reading_id], references: [id])

  @@unique([reading_id, date])
  @@index([date(sort: Desc)])
  @@map("metrics_daily")
}

model SiteMetrics {
  id          Int      @id @default(autoincrement())
  date        String   @unique
  total_views Int      @default(0)
  unlocks     Int      @default(0)
  revenue_cts Int      @default(0)
  wa_shares   Int      @default(0)
  new_pages   Int      @default(0)

  @@map("site_metrics")
}

model Product {
  id            String  @id @default(uuid())
  reading_id    String
  type          String
  name          String
  description   String?
  asin          String?
  affiliate_tag String  @default("sabia-21")
  price_usd     Float?
  url           String?
  youtube_id    String?
  clicks        Int     @default(0)
  sort_order    Int     @default(0)
  reading       Reading @relation(fields: [reading_id], references: [id])

  @@index([reading_id])
  @@map("products_affiliates")
}
