{
  "site": {
    "domain": "https://sintomario.org",
    "title": "SINTOMARIO.ORG - El Diccionario del Síntoma",
    "description": "Plataforma holística de información optimizada para SEO que responde búsquedas de síntomas con artículos de profundidad real.",
    "author": "SINTOMARIO.ORG",
    "language": "es",
    "charset": "UTF-8"
  },
  "build": {
    "output_dir": "public",
    "template_dir": "templates",
    "corpus_dir": "corpus"
  },
  "seo": {
    "default_title": "SINTOMARIO.ORG",
    "title_separator": " | ",
    "meta_description_length": 155,
    "title_max_length": 60,
    "enable_canonical": true,
    "enable_opengraph": true,
    "enable_twitter_cards": true,
    "enable_json_ld": true
  },
  "amazon": {
    "tag": "sintomario-20",
    "locale": "es",
    "region": "es-east-1",
    "enable_api": false,
    "rate_limit": {
      "requests_per_second": 1,
      "requests_per_hour": 3600
    }
  },
  "content": {
    "min_word_count": 200,
    "max_word_count": 3000,
    "enable_internal_links": true,
    "max_internal_links": 3,
    "enable_related_content": true
  },
  "performance": {
    "enable_caching": true,
    "cache_ttl": 3600,
    "enable_compression": true,
    "enable_minification": false
  },
  "analytics": {
    "enable_google_analytics": false,
    "enable_search_console": true,
    "enable_affiliate_tracking": true
  }
}
